{
  "title": "GPUOpt Cluster Overview",
  "uid": "gpuopt-cluster",
  "tags": ["gpuopt"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "title": "Total GPUs per Cluster",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "gpuopt_cluster_gpu_total", "legendFormat": "{{cluster_id}}"}],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "thresholds": {"steps": [{"color": "blue"}]}
        }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "avg(gpuopt_cluster_gpu_utilization)", "legendFormat": "Avg Util"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {"steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 50},
            {"color": "red", "value": 80}
          ]}
        }
      }
    },
    {
      "title": "Policy Evolutions",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "gpuopt_policy_evolutions_total", "legendFormat": "Evolutions"}]
    },
    {
      "title": "Jobs Scheduled",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(gpuopt_scheduled_jobs_total[5m])", "legendFormat": "Jobs/sec"}
      ]
    },
    {
      "title": "HTTP Requests",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(gpuopt_http_requests_total[5m])", "legendFormat": "{{method}} {{path}}"}
      ]
    }
  ]
}
